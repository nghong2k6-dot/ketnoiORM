@model List<ORM1.Models.Book>

<h2>Danh sách sách</h2>

<p>
    <a asp-action="Create">Thêm mới</a>
</p>

<table border="1" cellpadding="5">
    <tr>
        <th>ID</th>
        <th>Tên sách</th>
        <th>Giá</th>
        <th>Chức năng</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.Price.ToString("N0") VNĐ</td>
            <td>
                <a asp-action="Edit"
                   asp-route-id="@item.Id">Sửa</a>

                |

                <a asp-action="Delete"
                   asp-route-id="@item.Id">Xóa</a>
            </td>
        </tr>
    }
</table>
