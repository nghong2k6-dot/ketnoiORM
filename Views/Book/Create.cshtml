@model ORM1.Models.Book

<h2>Thêm sách</h2>

<form asp-action="Create" method="post">

    <div>
        <label>Tên sách</label>
        <input asp-for="Name" />
    </div>

    <br />

    <div>
        <label>Giá</label>
        <input asp-for="Price" />
    </div>

    <br />

    <button type="submit">
        Lưu
    </button>

</form>

<br />

<a asp-action="Index">Quay lại</a>
